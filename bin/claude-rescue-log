#!/usr/bin/env bash
# claude-rescue-log — single dispatch point for everything claude-rescue
# does in response to events from Claude Code, tmux, and tmux-resurrect.
#
# Event subcommands (writer):
#   session_start              Read JSON from stdin (Claude SessionStart hook).
#                                Event carries optional `claude_pid` field when
#                                find_my_claude_pid finds an ancestor claude.
#   session_end                Read JSON from stdin (Claude SessionEnd hook).
#                                Event carries optional `claude_pid` (same source).
#   user_prompt_submit         Mark current pane busy (UserPromptSubmit hook).
#                                Busy marker body is `{ts, claude_pid?}` JSON.
#   pre_tool_use               Refresh busy mtime (PreToolUse hook).
#   post_tool_use              Refresh busy mtime (PostToolUse hook).
#   stop                       Clear busy marker (Stop hook).
#   title <pane_id> <title>    Schedule a debounced title commit.
#   title-commit <pane_id>     Internal: commit a debounced title if still settled.
#   pane-died <pane_id>        Final flush before tmux reaps a pane.
#   client-detached            Logged at server-wide level (no pane).
#   hibernated <pane_id> <pids> <mode>  Hibernation layer event (soft|hard|skip).
#   unhibernated <pane_id> <mode>       Hibernation layer event.
#
# Resurrect hooks:
#   resurrect-save <state_file>   Write @claude-window-id sidecar (post-save-layout).
#   resurrect-restore             Re-apply @claude-window-id from sidecar (post-restore-all).
#
# Hibernation layer (focus-driven pane suspension):
#   hibernate-arm <pane_id> <pane_pid>   Schedule soft Ctrl+Z after SOFT_DELAY,
#                                         hard `/exit` (with SIGTERM/SIGKILL
#                                         fallback) after HARD_DELAY total.
#   hibernate-resume <pane_id>           Cancel arm + fg the soft-suspended job.
#                                         For mode=hard, leaves the in-flight
#                                         arm subshell alone so its `clr <sid>`
#                                         pre-fill completes.
#   arm-sweep                             Walk every pane and arm any backgrounded
#                                         claude pane that isn't already armed.
#                                         Triggered on client-attached /
#                                         client-session-changed so the user
#                                         doesn't have to physically visit
#                                         each pane to start the countdown.
#
# All output goes to stderr. Stdout is reserved (Claude hooks pipe stdout into context).

set -uo pipefail

# Resolve $0 through any symlinks so we find the real lib/common.sh, regardless
# of how this binary was invoked (direct, via ~/.local/bin/ symlink, etc.).
__script="$0"
while [ -L "$__script" ]; do
  __link="$(readlink "$__script")"
  case "$__link" in
    /*) __script="$__link" ;;
    *)  __script="$(cd "$(dirname "$__script")" && pwd)/$__link" ;;
  esac
done
REPO="$(cd "$(dirname "$__script")/.." && pwd)"
# shellcheck source=../lib/common.sh
. "$REPO/lib/common.sh"

ensure_dirs

DEBOUNCE_SECONDS="${CLAUDE_RESCUE_TITLE_DEBOUNCE:-5}"

# --- Subcommand handlers ----------------------------------------------------

cmd_session_start() {
  local json
  json="$(cat)"
  local session_id cwd source model transcript hook_event
  session_id="$(jq -r '.session_id // empty' <<<"$json")"
  cwd="$(jq -r '.cwd // empty' <<<"$json")"
  source="$(jq -r '.source // empty' <<<"$json")"
  model="$(jq -r '.model // empty' <<<"$json")"
  transcript="$(jq -r '.transcript_path // empty' <<<"$json")"
  hook_event="$(jq -r '.hook_event_name // empty' <<<"$json")"

  if [ -z "$session_id" ]; then
    log_err "session_start: missing session_id in stdin JSON"
    return 0
  fi

  local pane_id="${TMUX_PANE:-}"
  if [ -z "$pane_id" ] || [ -z "${TMUX:-}" ]; then
    log_no_tmux session_start "$session_id" "$cwd" "$source" "$model" "$transcript"
    return 0
  fi

  local window_uuid pane_uuid
  window_uuid="$(ensure_window_uuid "$pane_id")" || {
    log_err "session_start: failed to ensure window uuid for $pane_id"
    return 0
  }
  pane_uuid="$(ensure_pane_uuid "$pane_id")"

  # Force-flush any pending title for this pane (so /clear or /compact preserve last task).
  flush_pending_title "$pane_id" "$window_uuid"

  # On /clear or /compact: emit synthetic session_end for the prior session in this pane.
  if [ "$source" = "clear" ] || [ "$source" = "compact" ]; then
    local prior
    prior="$(latest_open_session_in_pane "$window_uuid" "$pane_uuid")"
    if [ -n "$prior" ]; then
      append_event "$window_uuid" "$(jq -nc \
        --arg ts "$(now_iso)" --arg sid "$prior" \
        --arg puuid "$pane_uuid" --arg reason "$source" \
        '{ts:$ts, kind:"session_end", session_id:$sid, pane_uuid:$puuid, reason:$reason}')"
    fi
  fi

  local session_name window_index window_name pane_cwd claude_pid
  IFS=$'\t' read -r session_name window_index window_name pane_cwd \
    < <(tmux_pane_info "$pane_id" || echo $'\t\t\t')
  claude_pid="$(find_my_claude_pid 2>/dev/null || true)"

  append_event "$window_uuid" "$(jq -nc \
    --arg ts "$(now_iso)" --arg sid "$session_id" \
    --arg puuid "$pane_uuid" \
    --arg cwd "${cwd:-$pane_cwd}" --arg src "$source" --arg model "$model" \
    --arg tr "$transcript" --arg sn "$session_name" --arg wn "$window_name" \
    --arg cpid "${claude_pid:-}" \
    '{ts:$ts, kind:"session_start", session_id:$sid, pane_uuid:$puuid,
      cwd:$cwd, source:$src, model:$model, transcript_path:$tr,
      session_name:$sn, window_name:$wn} +
     (if $cpid == "" then {} else {claude_pid:($cpid | tonumber)} end)')"

  # Update the pane's active session_id. Fires on every source (startup,
  # resume, clear, compact), so an in-claude `/resume` that switches sessions
  # overwrites this with the new sid — claude-rescue-resume reads it next
  # crash-restore in preference to tmux-resurrect's frozen saved `-r <sid>`.
  write_active_session "$pane_uuid" "$session_id"

  # claude is alive in this pane — any hibernated marker is now stale. This is
  # the cleanup point for hard-mode markers (focus-in is intentionally a no-op
  # so the marker survives as crash-restore insurance until claude is back).
  local hibernated_file="$CLAUDE_RESCUE_CACHE_HOME/hibernated/$pane_uuid.json"
  if [ -f "$hibernated_file" ]; then
    local stale_mode
    stale_mode="$(jq -r '.mode // empty' "$hibernated_file" 2>/dev/null)"
    rm -f "$hibernated_file"
    cmd_unhibernated "$pane_id" "${stale_mode:-hard}" 2>/dev/null || true
  fi

  rebuild_meta "$window_uuid"
}

cmd_session_end() {
  local json
  json="$(cat)"
  local session_id cwd
  session_id="$(jq -r '.session_id // empty' <<<"$json")"
  cwd="$(jq -r '.cwd // empty' <<<"$json")"

  if [ -z "$session_id" ]; then
    log_err "session_end: missing session_id in stdin JSON"
    return 0
  fi

  local pane_id="${TMUX_PANE:-}"
  if [ -z "$pane_id" ] || [ -z "${TMUX:-}" ]; then
    log_no_tmux session_end "$session_id" "$cwd" "" "" ""
    return 0
  fi

  # Reap session-tied state up front, independent of whether the window log
  # is reachable. This MUST happen even when @claude-window-id is missing
  # (e.g. claude crashed before SessionStart fired, or the window option
  # was lost), so orphan arm.pid / active files don't accumulate.
  #   - arm.pid: a pending hibernation timer would otherwise tick down to a
  #     plain zsh and send Ctrl+Z (benign no-op, but wrong). 27 such orphans
  #     observed in production after users dismissed "Resume from summary?".
  #   - active session_id file: no live session, no truth to record. Wrapper
  #     falls back to find-sessions (priority 2) keyed by the still-set
  #     @claude-pane-id.
  #   - busy marker: safety net if Stop didn't fire (e.g. claude crashed).
  #
  # KEEP @claude-pane-id intact. The hard-hibernation marker is keyed by
  # pane_uuid, and cmd_session_start uses it as the cleanup key when claude
  # returns to this pane (e.g. via the `clr <sid>` pre-fill). Unsetting it
  # here would orphan the marker — ensure_pane_uuid would mint a fresh UUID
  # at next SessionStart and never find the old marker. find-sessions
  # lookups for prior history also need the durable pane identity.
  local pane_uuid
  pane_uuid="$(tmux_get_pane_uuid "$pane_id")"
  local san="${pane_id//[^A-Za-z0-9]/_}"
  rm -f "$CLAUDE_RESCUE_CACHE_HOME/hibernated/$san.arm.pid"
  clear_active_session "$pane_uuid"
  clear_busy "$pane_uuid"

  local window_uuid
  window_uuid="$(tmux_get_window_uuid "$pane_id")"
  if [ -z "$window_uuid" ]; then
    log_err "session_end: no @claude-window-id on pane $pane_id; cleanup done but skipping event log"
    return 0
  fi

  flush_pending_title "$pane_id" "$window_uuid"

  local claude_pid
  claude_pid="$(find_my_claude_pid 2>/dev/null || true)"
  append_event "$window_uuid" "$(jq -nc \
    --arg ts "$(now_iso)" --arg sid "$session_id" \
    --arg puuid "$pane_uuid" --arg reason "exit" \
    --arg cpid "${claude_pid:-}" \
    '{ts:$ts, kind:"session_end", session_id:$sid, pane_uuid:$puuid, reason:$reason} +
     (if $cpid == "" then {} else {claude_pid:($cpid | tonumber)} end)')"

  rebuild_meta "$window_uuid"
}

cmd_title() {
  local pane_id="$1" title="$2"
  [ -z "$pane_id" ] && return 0
  [ -z "$title" ] && return 0

  local cand="$CLAUDE_RESCUE_CACHE_HOME/tmp/title-${pane_id//[^A-Za-z0-9]/_}.json"
  jq -nc --arg t "$title" --arg ts "$(now_iso)" '{title:$t, ts:$ts}' > "$cand"

  # Schedule a debounced commit. Multiple sleeps may stack; only the one whose
  # candidate is still settled at commit time will write the event.
  ( sleep "$DEBOUNCE_SECONDS"
    "$REPO/bin/claude-rescue-log" title-commit "$pane_id" >/dev/null 2>&1 ) &
  disown 2>/dev/null || true
}

cmd_title_commit() {
  local pane_id="$1"
  local cand="$CLAUDE_RESCUE_CACHE_HOME/tmp/title-${pane_id//[^A-Za-z0-9]/_}.json"
  local last="$CLAUDE_RESCUE_CACHE_HOME/tmp/title-last-${pane_id//[^A-Za-z0-9]/_}.txt"
  [ -f "$cand" ] || return 0

  local title cand_ts now elapsed
  title="$(jq -r '.title' "$cand")"
  cand_ts="$(jq -r '.ts' "$cand")"
  now="$(now_iso)"

  # Settle check: candidate must be at least DEBOUNCE_SECONDS old.
  elapsed=$(iso_age_seconds "$cand_ts")
  [ "$elapsed" -lt "$DEBOUNCE_SECONDS" ] && return 0

  # Dedup: skip if we already emitted this exact title for this pane.
  if [ -f "$last" ] && [ "$(cat "$last")" = "$title" ]; then
    return 0
  fi

  local window_uuid session_id pane_uuid
  window_uuid="$(tmux_get_window_uuid "$pane_id")"
  [ -z "$window_uuid" ] && return 0
  pane_uuid="$(tmux_get_pane_uuid "$pane_id")"
  session_id="$(latest_open_session_in_pane "$window_uuid" "$pane_uuid")"

  append_event "$window_uuid" "$(jq -nc \
    --arg ts "$now" --arg t "$title" \
    --arg puuid "$pane_uuid" --arg sid "${session_id:-}" \
    '{ts:$ts, kind:"title", pane_uuid:$puuid, title:$t} +
     (if $sid == "" then {} else {session_id:$sid} end)')"
  printf '%s' "$title" > "$last"
  rebuild_meta "$window_uuid"
}

cmd_pane_died() {
  local pane_id="$1"
  [ -z "$pane_id" ] && return 0
  # Pane is gone, but window options may still resolve via the parent window.
  local window_uuid pane_uuid
  window_uuid="$(tmux_get_window_uuid "$pane_id")" || true
  [ -z "$window_uuid" ] && return 0
  # Pane option likely already gone with the pane; best-effort.
  pane_uuid="$(tmux_get_pane_uuid "$pane_id")"

  flush_pending_title "$pane_id" "$window_uuid"
  append_event "$window_uuid" "$(jq -nc \
    --arg ts "$(now_iso)" --arg puuid "$pane_uuid" \
    '{ts:$ts, kind:"pane_died", pane_uuid:$puuid}')"

  # Pane is gone — any hibernated marker for it is orphaned. Best-effort
  # cleanup (only if we resolved a pane_uuid above).
  if [ -n "$pane_uuid" ]; then
    rm -f "$CLAUDE_RESCUE_CACHE_HOME/hibernated/$pane_uuid.json"
    clear_active_session "$pane_uuid"
  fi
  local san="${pane_id//[^A-Za-z0-9]/_}"
  rm -f "$CLAUDE_RESCUE_CACHE_HOME/hibernated/$san.arm.pid"

  rebuild_meta "$window_uuid"
}

cmd_client_detached() {
  # Server-wide event; no pane attribution. Best-effort: log for forensic context.
  local marker="$CLAUDE_RESCUE_CACHE_HOME/client-detached.log"
  printf '%s\n' "$(now_iso)" >> "$marker"
}

cmd_hibernated() {
  # Args: $1 = pane_id, $2 = pids (or skip reason like "skip:busy"),
  #       $3 = mode ("soft"|"hard"|"skip")
  local pane_id="$1" pids="${2:-}" mode="${3:-soft}"
  [ -z "$pane_id" ] && return 0
  local window_uuid session_id pane_uuid
  window_uuid="$(tmux_get_window_uuid "$pane_id")" || true
  [ -z "$window_uuid" ] && return 0
  pane_uuid="$(tmux_get_pane_uuid "$pane_id")"
  session_id="$(latest_open_session_in_pane "$window_uuid" "$pane_uuid")"
  append_event "$window_uuid" "$(jq -nc \
    --arg ts "$(now_iso)" --arg puuid "$pane_uuid" \
    --arg pids "$pids" --arg sid "${session_id:-}" --arg mode "$mode" \
    '{ts:$ts, kind:"hibernated", pane_uuid:$puuid, pids:$pids, mode:$mode} +
     (if $sid == "" then {} else {session_id:$sid} end)')"
}

cmd_unhibernated() {
  # Args: $1 = pane_id, $2 = mode previously hibernated as ("soft"|"hard")
  local pane_id="$1" mode="${2:-}"
  [ -z "$pane_id" ] && return 0
  local window_uuid session_id pane_uuid
  window_uuid="$(tmux_get_window_uuid "$pane_id")" || true
  [ -z "$window_uuid" ] && return 0
  pane_uuid="$(tmux_get_pane_uuid "$pane_id")"
  session_id="$(latest_open_session_in_pane "$window_uuid" "$pane_uuid")"
  append_event "$window_uuid" "$(jq -nc \
    --arg ts "$(now_iso)" --arg puuid "$pane_uuid" \
    --arg sid "${session_id:-}" --arg mode "$mode" \
    '{ts:$ts, kind:"unhibernated", pane_uuid:$puuid, mode:$mode} +
     (if $sid == "" then {} else {session_id:$sid} end)')"
}

# --- Helpers used by handlers -----------------------------------------------

# Returns the session_id of the most recent session_start in this window+pane
# that has not been followed by a session_end (or empty if none).
# Pane is identified by its durable pane_uuid (@claude-pane-id), not the
# transient tmux %N pane_id.
latest_open_session_in_pane() {
  # Returns the session_id of the most recent session_start in this window+pane,
  # ordered by event timestamp (NOT insertion order). The previous reduce-based
  # implementation returned the first-seen session_id whose latest event was a
  # start, which misattributed when a pane switched between sessions without an
  # explicit SessionEnd (claude doesn't fire SessionEnd when the user resumes
  # a different session — only on /clear, /compact, and exit).
  local window_uuid="$1" pane_uuid="$2"
  local log="$CLAUDE_RESCUE_DATA_HOME/windows/$window_uuid.jsonl"
  [ -f "$log" ] || return 0
  [ -z "$pane_uuid" ] && return 0
  jq -rs --arg puuid "$pane_uuid" '
    [.[] | select(.pane_uuid == $puuid and (.kind | startswith("session_start")))]
    | sort_by(.ts) | last | .session_id // empty
  ' "$log"
}

flush_pending_title() {
  local pane_id="$1" window_uuid="$2"
  local cand="$CLAUDE_RESCUE_CACHE_HOME/tmp/title-${pane_id//[^A-Za-z0-9]/_}.json"
  local last="$CLAUDE_RESCUE_CACHE_HOME/tmp/title-last-${pane_id//[^A-Za-z0-9]/_}.txt"
  [ -f "$cand" ] || return 0
  local title
  title="$(jq -r '.title' "$cand")"
  if [ -f "$last" ] && [ "$(cat "$last")" = "$title" ]; then
    return 0
  fi
  local session_id pane_uuid
  pane_uuid="$(tmux_get_pane_uuid "$pane_id")"
  session_id="$(latest_open_session_in_pane "$window_uuid" "$pane_uuid")"
  append_event "$window_uuid" "$(jq -nc \
    --arg ts "$(now_iso)" --arg t "$title" \
    --arg puuid "$pane_uuid" --arg sid "${session_id:-}" \
    '{ts:$ts, kind:"title", pane_uuid:$puuid, title:$t, forced:true} +
     (if $sid == "" then {} else {session_id:$sid} end)')"
  printf '%s' "$title" > "$last"
}

iso_age_seconds() {
  local ts="$1"
  local then now
  then="$(date -u -j -f "%Y-%m-%dT%H:%M:%SZ" "$ts" "+%s" 2>/dev/null)" || { echo 0; return; }
  now="$(date -u +%s)"
  echo $((now - then))
}

log_no_tmux() {
  local kind="$1" sid="$2" cwd="$3" source="$4" model="$5" transcript="$6"
  local host bucket
  host="$(hostname -s)"
  bucket="$CLAUDE_RESCUE_DATA_HOME/no-tmux/${host}__$(printf '%s' "$cwd" | shasum | cut -c1-12).jsonl"
  printf '%s\n' "$(jq -nc \
    --arg ts "$(now_iso)" --arg k "$kind" --arg sid "$sid" --arg cwd "$cwd" \
    --arg src "$source" --arg model "$model" --arg tr "$transcript" \
    '{ts:$ts, kind:$k, session_id:$sid, cwd:$cwd, source:$src, model:$model, transcript_path:$tr}')" \
    >> "$bucket"
}

# --- Resurrect hooks (post-save-layout / post-restore-all) ------------------

cmd_resurrect_save() {
  # Hooked into tmux-resurrect via @resurrect-hook-post-save-layout.
  # Two jobs:
  #   1. Write the @claude-window-id sidecar (so UUIDs survive a kill-server cycle).
  #   2. Sample per-pane state and emit title transitions / pane-died events.
  #      This replaces the pane-title-changed and pane-died tmux hooks, which
  #      don't register at server-global scope on tmux 3.x. Granularity matches
  #      the continuum save interval (typically 1 minute).
  local state_file="${1:-}"
  [ -n "$state_file" ] || return 0
  [ -f "$state_file" ] || return 0

  # 1. Sidecar — preserves @claude-window-id AND @claude-pane-id across server
  # restarts. Format is type-prefixed TSV; restore reads each line by leading
  # column. Legacy 4-column rows (no leading type) are still understood by
  # the restore handler for backwards compat.
  #   window<TAB>session<TAB>window_idx<TAB>window_name<TAB>uuid
  #   pane<TAB>session<TAB>window_idx<TAB>pane_idx<TAB>pane_uuid
  #
  # Sentinel-encode internal empties (`-` for any empty field) so bash's
  # `IFS=$'\t' read` at restore time doesn't collapse them. Tab is whitespace
  # in IFS, and consecutive whitespace IFS chars get coalesced — without this,
  # an empty window_name silently shifts subsequent fields, making the uuid
  # read as col4 and col5 empty. Same trick as state-dump.sh's restore-plan
  # synth.
  local sidecar="${state_file%.txt}.claude-userops.tsv"
  # OFS="\t" is required: modifying $i triggers awk to reconstruct $0 using
  # OFS, which defaults to space. Without it, the sentinel'd row would have
  # space-separated fields and the restore-side `IFS=$'\t' read` would treat
  # the whole line as col1.
  {
    tmux list-windows -aF $'window\t#{session_name}\t#{window_index}\t#{window_name}\t#{@claude-window-id}' \
      | awk -F'\t' 'BEGIN{OFS="\t"} NF==5 && $5 != "" {
          for (i=1;i<=NF;i++) if ($i=="") $i="-"
          print
        }'
    tmux list-panes -aF $'pane\t#{session_name}\t#{window_index}\t#{pane_index}\t#{@claude-pane-id}' \
      | awk -F'\t' 'BEGIN{OFS="\t"} NF==5 && $5 != "" {
          for (i=1;i<=NF;i++) if ($i=="") $i="-"
          print
        }'
  } > "$sidecar.tmp"
  mv "$sidecar.tmp" "$sidecar"

  # 2. Per-pane sample — emit title transitions and detect pane death.
  local snapshot_dir="$CLAUDE_RESCUE_CACHE_HOME/tmp/last-pane-state"
  mkdir -p "$snapshot_dir"
  local current_panes_file="$snapshot_dir/.current-panes"
  : > "$current_panes_file"

  # Use ASCII unit separator (\x1f) instead of tab. Bash's `read` collapses
  # consecutive whitespace IFS chars (including tabs), which silently drops
  # empty fields like an unset pane_title — shifting subsequent fields and
  # making @claude-window-id read empty. Non-whitespace IFS preserves them.
  local US=$'\x1f'
  while IFS="$US" read -r pane_id session_name window_index window_name pane_title pane_cwd window_uuid pane_uuid; do
    [ -z "$pane_id" ] && continue
    [ -z "$window_uuid" ] && continue
    printf '%s\n' "$pane_id" >> "$current_panes_file"

    local san="${pane_id//[^A-Za-z0-9]/_}"
    local last_file="$snapshot_dir/$san.last"
    local prev_title=""
    [ -f "$last_file" ] && prev_title="$(cat "$last_file" 2>/dev/null)"

    if [ -n "$pane_title" ] && [ "$pane_title" != "$prev_title" ]; then
      local session_id
      session_id="$(latest_open_session_in_pane "$window_uuid" "$pane_uuid")"
      append_event "$window_uuid" "$(jq -nc \
        --arg ts "$(now_iso)" --arg t "$pane_title" \
        --arg puuid "$pane_uuid" --arg sid "${session_id:-}" \
        '{ts:$ts, kind:"title", pane_uuid:$puuid, title:$t} +
         (if $sid == "" then {} else {session_id:$sid} end)')"
      printf '%s' "$pane_title" > "$last_file"
    fi
  done < <(tmux list-panes -aF "#{pane_id}${US}#{session_name}${US}#{window_index}${US}#{window_name}${US}#{pane_title}${US}#{pane_current_path}${US}#{@claude-window-id}${US}#{@claude-pane-id}")

  # 2b. Detect panes that disappeared since last sample (deferred pane-died).
  # Defensive guard: if this sample saw ZERO live panes with @claude-window-id,
  # tmux's option lookup likely returned a transient empty (observed when a
  # pane's command transitions, e.g. claude → zsh on Ctrl+C+Ctrl+C — the
  # save fires in the middle of automatic-rename and the option query
  # briefly returns nothing). Skip the gone-pane detection and wait for the
  # next sample rather than firing false positive pane_died events.
  if [ ! -s "$current_panes_file" ]; then
    log_err "resurrect-save: list-panes returned no live windows with @claude-window-id; skipping gone-pane detection"
    rm -f "$current_panes_file"
    return 0
  fi

  local stale_pane
  for stale_file in "$snapshot_dir"/*.last; do
    [ -f "$stale_file" ] || continue
    stale_pane="$(basename "$stale_file" .last)"
    # Walk back to find the original pane_id by inverting the sanitization.
    # Sanitization is one-way (multiple chars → underscore), so we record the
    # full pane_id in a sidecar.
    local owner_file="$snapshot_dir/$stale_pane.owner"
    [ -f "$owner_file" ] || { rm -f "$stale_file"; continue; }
    local original_pane_id
    original_pane_id="$(cat "$owner_file")"
    if ! grep -qxF "$original_pane_id" "$current_panes_file" 2>/dev/null; then
      # Pane no longer exists; emit pane_died if we have a window UUID for it.
      local last_window_uuid_file="$snapshot_dir/$stale_pane.window_uuid"
      local last_pane_uuid_file="$snapshot_dir/$stale_pane.pane_uuid"
      [ -f "$last_window_uuid_file" ] || { rm -f "$stale_file" "$owner_file" "$last_pane_uuid_file"; continue; }
      local last_window_uuid last_pane_uuid
      last_window_uuid="$(cat "$last_window_uuid_file")"
      last_pane_uuid="$(cat "$last_pane_uuid_file" 2>/dev/null || true)"
      append_event "$last_window_uuid" "$(jq -nc \
        --arg ts "$(now_iso)" --arg puuid "$last_pane_uuid" \
        '{ts:$ts, kind:"pane_died", pane_uuid:$puuid, source:"resurrect_sample"}')"
      rm -f "$stale_file" "$owner_file" "$last_window_uuid_file" "$last_pane_uuid_file"
    fi
  done

  # 2c. Update owner + window_uuid + pane_uuid sidecars for currently-live panes.
  # Same US separator as above to handle empty pane_title correctly.
  while IFS="$US" read -r pane_id _ _ _ _ _ window_uuid pane_uuid; do
    [ -z "$pane_id" ] && continue
    [ -z "$window_uuid" ] && continue
    local san="${pane_id//[^A-Za-z0-9]/_}"
    printf '%s' "$pane_id" > "$snapshot_dir/$san.owner"
    printf '%s' "$window_uuid" > "$snapshot_dir/$san.window_uuid"
    printf '%s' "$pane_uuid" > "$snapshot_dir/$san.pane_uuid"
  done < <(tmux list-panes -aF "#{pane_id}${US}#{session_name}${US}#{window_index}${US}#{window_name}${US}#{pane_title}${US}#{pane_current_path}${US}#{@claude-window-id}${US}#{@claude-pane-id}")

  rm -f "$current_panes_file"

  # 2d. Rebuild metas for any windows we touched.
  for log in "$CLAUDE_RESCUE_DATA_HOME/windows/"*.jsonl; do
    [ -f "$log" ] || continue
    rebuild_meta "$(basename "$log" .jsonl)"
  done
}

cmd_resurrect_restore() {
  # Hooked into tmux-resurrect via @resurrect-hook-pre-restore-pane-processes.
  # Re-applies @claude-window-id and @claude-pane-id from the sidecar TSV.
  # Accepts two formats:
  #   legacy (4 cols): session<TAB>window_idx<TAB>window_name<TAB>@claude-window-id
  #   current (5 cols, type-prefixed):
  #     window<TAB>session<TAB>window_idx<TAB>window_name<TAB>uuid
  #     pane<TAB>session<TAB>window_idx<TAB>pane_idx<TAB>uuid
  log_err "resurrect-restore: hook fired (TMUX=${TMUX:-<unset>})"
  local resurrect_dir
  resurrect_dir="$(tmux show-options -gv @resurrect-dir 2>/dev/null || true)"
  if [ -z "$resurrect_dir" ]; then
    resurrect_dir="${XDG_DATA_HOME:-$HOME/.local/share}/tmux/resurrect"
    [ -d "$resurrect_dir" ] || resurrect_dir="$HOME/.tmux/resurrect"
  fi
  local last_link="$resurrect_dir/last"
  if ! { [ -L "$last_link" ] || [ -f "$last_link" ]; }; then
    log_err "resurrect-restore: no last symlink at $last_link — bailing"
    return 0
  fi
  local state_basename
  state_basename="$(readlink "$last_link" 2>/dev/null || cat "$last_link" 2>/dev/null)"
  if [ -z "$state_basename" ]; then
    log_err "resurrect-restore: last symlink resolves to empty target — bailing"
    return 0
  fi
  local state_file="$resurrect_dir/$state_basename"
  local sidecar="${state_file%.txt}.claude-userops.tsv"
  if [ ! -f "$sidecar" ]; then
    log_err "resurrect-restore: no sidecar at $sidecar — bailing (snapshot=$state_basename)"
    return 0
  fi
  log_err "resurrect-restore: snapshot=$state_basename sidecar_rows=$(wc -l < "$sidecar" | tr -d ' ')"

  local applied_window=0 applied_pane=0 skipped=0
  while IFS=$'\t' read -r col1 col2 col3 col4 col5; do
    # Decode sentinel-encoded empties (`-` → empty). Matches the encoding in
    # cmd_resurrect_save. Only col4 (window_name / pane_idx) and col5 (uuid)
    # are realistically subject to encoding; col1-col3 are never empty for
    # well-formed rows.
    [ "$col4" = "-" ] && col4=""
    [ "$col5" = "-" ] && col5=""
    if [ -z "$col5" ]; then
      # Legacy 4-col line: window only.
      [ -n "$col4" ] || { skipped=$((skipped+1)); continue; }
      tmux set-option -wt "$col1:$col2" @claude-window-id "$col4" 2>/dev/null \
        && applied_window=$((applied_window+1)) \
        || log_err "resurrect-restore: set-option -wt $col1:$col2 @claude-window-id failed"
    else
      case "$col1" in
        window)
          [ -n "$col5" ] || { skipped=$((skipped+1)); continue; }
          tmux set-option -wt "$col2:$col3" @claude-window-id "$col5" 2>/dev/null \
            && applied_window=$((applied_window+1)) \
            || log_err "resurrect-restore: set-option -wt $col2:$col3 @claude-window-id failed"
          ;;
        pane)
          [ -n "$col5" ] || { skipped=$((skipped+1)); continue; }
          tmux set-option -pt "$col2:$col3.$col4" @claude-pane-id "$col5" 2>/dev/null \
            && applied_pane=$((applied_pane+1)) \
            || log_err "resurrect-restore: set-option -pt $col2:$col3.$col4 @claude-pane-id failed"
          ;;
      esac
    fi
  done < "$sidecar"
  log_err "resurrect-restore: applied window=$applied_window pane=$applied_pane skipped=$skipped"

  # === Crash-promote: any pane that was soft-hibernated when the server died
  # is effectively hard-hibernated now (claude died with the crash). Rewrite
  # the marker so hibernate-resume on next focus-in is a no-op (no spurious
  # `fg<Enter>` to a fresh shell with no suspended job).
  local marker current_mode
  for marker in "$CLAUDE_RESCUE_CACHE_HOME"/hibernated/*.json; do
    [ -f "$marker" ] || continue
    current_mode="$(jq -r '.mode // empty' "$marker" 2>/dev/null)"
    if [ "$current_mode" = "soft" ]; then
      jq --arg mode "hard" --arg ts "$(now_iso)" \
         '. + {mode:$mode, hard_ts:$ts, hard_source:"crash-promote"}' \
         "$marker" > "$marker.tmp" && mv "$marker.tmp" "$marker"
    fi
  done
  # Stale arm pid files refer to processes from the dead server.
  rm -f "$CLAUDE_RESCUE_CACHE_HOME"/hibernated/*.arm.pid

  # Stale active-session files refer to claude processes that died with the
  # server. Restored panes are about to run claude-rescue-resume → SessionStart,
  # which writes a fresh active file. Clear the directory rather than leave
  # entries pointing at sessions whose pane_uuid mapping may have shifted.
  rm -f "$CLAUDE_RESCUE_DATA_HOME"/active/*

  # === Post-restore UX: for each pane with a hard-hibernation marker AND no
  # live claude process, run `claude-rescue print` (shows the captured
  # snapshot) and pre-fill `clr <sid>` (no Enter — user reviews and presses
  # Enter to resume). Skip if claude is alive in the pane: tmux-resurrect
  # reports pane_current_command='claude' even when claude was Ctrl+Z'd to
  # background, so soft-hibernated panes get auto-resumed by the resurrect
  # @resurrect-processes wrapper. In that case, sending keys would feed text
  # into the running claude — not what we want.
  #
  # Done in a backgrounded subshell to avoid blocking the pre-restore hook;
  # sleeps long enough for resurrect to finish launching pane processes and
  # the shell (or restored claude) to render its prompt.
  (
    exec </dev/null >/dev/null 2>>"$CLAUDE_RESCUE_CACHE_HOME/restore-keys.err"
    sleep 5

    local pane_id pane_uuid hib_marker mode hard_source sid cap_meta
    while IFS=$'\t' read -r pane_id pane_uuid; do
      [ -n "$pane_uuid" ] || continue
      hib_marker="$CLAUDE_RESCUE_CACHE_HOME/hibernated/$pane_uuid.json"
      [ -f "$hib_marker" ] || continue
      mode="$(jq -r '.mode // empty' "$hib_marker" 2>/dev/null)"
      [ "$mode" = "hard" ] || continue

      # Discriminate by INTENT, not by current state. A crash-promoted marker
      # means a soft-hibernated pane that resurrect is bringing back via the
      # wrapper — the foreground process is racing through
      # shell → claude-rescue-resume → claude, and pane_current_command could
      # report any of those depending on timing. Sending keys into that pipeline
      # corrupts the resume. Skip; marker will be cleaned up by cmd_session_start
      # when the wrapper-launched claude fires its SessionStart hook.
      hard_source="$(jq -r '.hard_source // empty' "$hib_marker" 2>/dev/null)"
      if [ "$hard_source" = "crash-promote" ]; then
        continue
      fi

      cap_meta="$CLAUDE_RESCUE_DATA_HOME/captures/$pane_uuid.json"
      sid="$(jq -r '.session_id // empty' "$cap_meta" 2>/dev/null)"

      # 1. Print the captured snapshot (uses default-arg path which reads
      #    @claude-pane-id re-applied from the sidecar above).
      tmux send-keys -t "$pane_id" "claude-rescue print" Enter 2>/dev/null || true
      sleep 0.5
      # 2. Pre-fill resume command (no Enter). User hits Enter to start.
      if [ -n "$sid" ]; then
        tmux send-keys -t "$pane_id" "clr $sid" 2>/dev/null || true
      fi

      # Marker NOT deleted here. The `clr <sid>` text is live readline input
      # (not captured by tmux-resurrect), so a second crash before the user
      # presses Enter would lose the recipe. cmd_session_start cleans it up
      # when claude actually restarts; cmd_pane_died handles orphans.
    done < <(tmux list-panes -aF $'#{pane_id}\t#{@claude-pane-id}' 2>/dev/null)
  ) &
  disown 2>/dev/null || true
}

# --- Busy markers (deterministic claude-busy state, hook-driven) ------------
# UserPromptSubmit / PreToolUse / PostToolUse mark the pane busy by touching
# $CACHE/busy/<pane_uuid>. Stop / SessionEnd clear it. cmd_hibernate_arm reads
# this instead of grep'ing the streaming spinner glyph from the pane title —
# deterministic, theme-independent, no race against terminal repaint timing.
#
# The marker is keyed by pane_uuid (durable identity), so resurrect+restore
# across server restarts preserves attribution. Freshness window
# (CLAUDE_RESCUE_BUSY_FRESHNESS, default 1800s) prevents a crashed claude
# that never fired Stop from leaving the pane permanently "busy".

mark_busy() {
  # Args: $1 = pane_uuid, $2 = optional claude_pid
  # Writes a tiny JSON body {claude_pid, ts} into the marker so a stale or
  # confused marker can be traced back to which claude wrote it. The freshness
  # check in is_busy() still uses file mtime — we ignore the JSON body for
  # busy/idle decision; it's purely for troubleshooting.
  local pane_uuid="$1" claude_pid="${2:-}"
  [ -z "$pane_uuid" ] && return 0
  local f="$CLAUDE_RESCUE_CACHE_HOME/busy/$pane_uuid"
  jq -nc --arg ts "$(now_iso)" --arg cpid "$claude_pid" \
    '{ts:$ts} + (if $cpid == "" then {} else {claude_pid:($cpid | tonumber)} end)' \
    > "$f" 2>/dev/null || : > "$f" 2>/dev/null || true
}

clear_busy() {
  local pane_uuid="$1"
  [ -z "$pane_uuid" ] && return 0
  rm -f "$CLAUDE_RESCUE_CACHE_HOME/busy/$pane_uuid"
}

# Returns 0 if pane is busy AND marker mtime is within the freshness window.
is_busy() {
  local pane_uuid="$1"
  [ -z "$pane_uuid" ] && return 1
  local f="$CLAUDE_RESCUE_CACHE_HOME/busy/$pane_uuid"
  [ -f "$f" ] || return 1
  local freshness="${CLAUDE_RESCUE_BUSY_FRESHNESS:-1800}"
  local now mt
  now=$(date +%s)
  mt=$(stat -f %m "$f" 2>/dev/null || stat -c %Y "$f" 2>/dev/null || echo 0)
  [ "$((now - mt))" -lt "$freshness" ]
}

# Shared body for the four busy-tracking claude hooks. Reads (and discards)
# stdin — claude pipes hook-event JSON there, and not draining can stall the
# claude side on small writes. Looks up the calling claude's pid so the busy
# marker file body can be cross-referenced with session_start events for
# troubleshooting.
__busy_hook() {
  local action="$1"  # "mark" | "clear"
  cat >/dev/null 2>&1 || true
  local pane_id="${TMUX_PANE:-}"
  [ -z "$pane_id" ] && return 0
  [ -z "${TMUX:-}" ] && return 0
  local pane_uuid
  pane_uuid="$(tmux_get_pane_uuid "$pane_id" 2>/dev/null || true)"
  [ -z "$pane_uuid" ] && return 0
  case "$action" in
    mark)
      local claude_pid
      claude_pid="$(find_my_claude_pid 2>/dev/null || true)"
      mark_busy "$pane_uuid" "$claude_pid"
      ;;
    clear) clear_busy "$pane_uuid" ;;
  esac
}

cmd_user_prompt_submit() { __busy_hook mark ; }
cmd_pre_tool_use()       { __busy_hook mark ; }   # refreshes mtime mid-run
cmd_post_tool_use()      { __busy_hook mark ; }   # refreshes mtime mid-run
cmd_stop()               { __busy_hook clear ; }

# --- Hibernation layer (two-stage focus-driven pane suspension) -------------
#
# Stage 1 (SOFT): after CLAUDE_RESCUE_SOFT_DELAY (default 60min) of focus-out,
#   capture the pane scrollback to disk, then `tmux send-keys C-z`. The pane's
#   tty driver issues SIGTSTP to the foreground process group, claude (and any
#   uv/python tool children) stop cleanly, and the shell takes the terminal
#   back. Resume via shell job control (fg) preserves session and unfreezes
#   children correctly — unlike a raw `kill -STOP` / `kill -CONT` pair which
#   does not restore tcsetpgrp and can leave claude+children stuck in T after
#   the resume signal is delivered.
#
# Stage 2 (HARD): if the pane stays defocused and soft-hibernated for
#   CLAUDE_RESCUE_HARD_DELAY (default 24h), wake claude with `fg<Enter>` then
#   send `/exit<Enter>` for a clean shutdown (fires claude's SessionEnd, flushes
#   the transcript). Falls back to SIGTERM → SIGKILL on the recorded claude pids
#   if `/exit` doesn't terminate within ~3s. Frees all resources. The capture
#   file stays on disk for `claude-rescue print` so the user can recall context
#   and resume the session from the picker. The shell prompt is then pre-filled
#   with `clr <session_id>` (no Enter) so resume is one keystroke away.
#   (Task #48 tracks moving away from `/exit` to Ctrl+C × 2 to avoid polluting
#   claude's command history.)
#
# Resume (focus-in): hibernate-resume is called by the pane-focus-in tmux
#   hook. Soft → `fg<Enter>`. Hard → no-op (claude is gone; capture remains).
#
# Capture is the universal first step: written before the soft signal fires,
# so even if the send-keys path is broken, we still have the snapshot. The
# hard upgrade reuses the same capture (claude was suspended in between and
# couldn't have changed pane content).

cmd_hibernate_arm() {
  # Args: $1 = pane_id, $2 = pane_pid (root of pane's process tree).
  local pane_id="${1:-}" pane_pid="${2:-}"
  [ -n "$pane_id" ] || return 0
  [ -n "$pane_pid" ] || return 0

  # Fast guard: panes that have never run claude have no @claude-pane-id and
  # nothing worth hibernating. Skips a 60-minute disowned timer for every
  # focus-out on a plain shell pane.
  local _puuid
  _puuid="$(tmux_get_pane_uuid "$pane_id" 2>/dev/null || true)"
  [ -n "$_puuid" ] || return 0

  local SOFT_DELAY="${CLAUDE_RESCUE_SOFT_DELAY:-3600}"
  local HARD_DELAY="${CLAUDE_RESCUE_HARD_DELAY:-86400}"
  local DEFER_TIMES="${CLAUDE_RESCUE_HIBERNATE_DEFER_TIMES:-3}"
  local DEFER_SECONDS="${CLAUDE_RESCUE_HIBERNATE_DEFER_SECONDS:-60}"
  local TARGET_COMM="${CLAUDE_RESCUE_TARGET_COMM:-claude}"

  local san="${pane_id//[^A-Za-z0-9]/_}"
  local arm_pid_file="$CLAUDE_RESCUE_CACHE_HOME/hibernated/$san.arm.pid"
  local hibernated_file="$CLAUDE_RESCUE_CACHE_HOME/hibernated/$_puuid.json"

  # If a timer is already running for this pane, leave it. "Running" means:
  # pid alive AND its argv shows it's actually an arm subshell — defends
  # against pid recycling (a stale arm.pid pointing at an unrelated process
  # would otherwise block us from arming for the rest of the kernel pid
  # rollover window).
  if [ -f "$arm_pid_file" ]; then
    local prev_pid prev_args
    prev_pid="$(cat "$arm_pid_file" 2>/dev/null || true)"
    if [ -n "$prev_pid" ] && kill -0 "$prev_pid" 2>/dev/null; then
      prev_args="$(ps -o args= -p "$prev_pid" 2>/dev/null)"
      if printf '%s' "$prev_args" | grep -qE "claude-rescue-log (hibernate-arm|arm-sweep)"; then
        return 0
      fi
    fi
    rm -f "$arm_pid_file"
  fi

  (
    exec </dev/null >/dev/null 2>>"$CLAUDE_RESCUE_CACHE_HOME/hibernate.err"

    # Discover our own pid in a way that works on bash 3.2 (no $BASHPID).
    # `exec sh -c 'echo $PPID'` makes sh REPLACE the command-substitution
    # subshell at the same pid, then echo its parent's pid — which is *this*
    # outer subshell.
    local MY_PID
    MY_PID="$(exec sh -c 'echo $PPID')"

    # Orphan-safety: this subshell is detached from its tmux server (run-shell
    # -b). On kill -9 / teardown the server dies but we keep sleeping; when we
    # wake, the pane_id we captured might belong to a brand-new unrelated pane
    # on a fresh server (or no server at all). Before every side effect we
    # verify (a) the arm pid file still names *this* subshell and (b) the
    # pane's @claude-pane-id still matches the one we armed against. Either
    # mismatch → exit silently without touching tmux or any pid.
    arm_check() {
      if ! arm_still_authoritative "$arm_pid_file" "$MY_PID" "$pane_id" "$_puuid"; then
        exit 0
      fi
    }

    # ===== STAGE 1: SOFT (capture + Ctrl+Z) =====
    sleep "$SOFT_DELAY"
    arm_check

    # Busy-aware defer (UserPromptSubmit/Pre|PostToolUse touch the busy file;
    # Stop clears it). Skips title-spinner regex which depended on the
    # configured theme's streaming glyph.
    local active pids cur child cmd queue
    for _ in $(seq 1 "$DEFER_TIMES"); do
      if is_busy "$_puuid"; then sleep "$DEFER_SECONDS"; arm_check; else break; fi
    done

    if is_busy "$_puuid"; then
      cmd_hibernated "$pane_id" "skip:busy" "skip" 2>/dev/null || true
      rm -f "$arm_pid_file"
      exit 0
    fi

    active="$(tmux display-message -p -t "$pane_id" -F '#{window_active}#{pane_active}' 2>/dev/null || echo "00")"
    if [ "$active" = "11" ]; then
      rm -f "$arm_pid_file"
      exit 0
    fi

    # Walk pane process tree for record-keeping. We don't actually signal
    # individual PIDs anymore (Ctrl+Z via terminal handles the whole pgid),
    # but we record what claude PIDs were live at hibernation time.
    pids=""
    queue=("$pane_pid")
    while [ ${#queue[@]} -gt 0 ]; do
      cur="${queue[0]}"; queue=("${queue[@]:1}")
      for child in $(pgrep -P "$cur" 2>/dev/null); do
        queue+=("$child")
        cmd="$(ps -o comm= -p "$child" 2>/dev/null | sed 's|.*/||' | tr -d ' ')"
        [ "$cmd" = "$TARGET_COMM" ] && pids="$pids $child"
      done
    done
    pids="$(printf '%s\n' $pids | sort -u | tr '\n' ' ')"

    if [ -z "${pids// /}" ]; then
      rm -f "$arm_pid_file"
      exit 0
    fi

    # === Capture pane scrollback FIRST (before any signal). Universal — the
    # hard-upgrade stage reuses this exact capture. ===
    local window_uuid session_id cwd capture_txt capture_meta
    window_uuid="$(tmux_get_window_uuid "$pane_id" 2>/dev/null || true)"
    session_id=""
    [ -n "$window_uuid" ] && \
      session_id="$(latest_open_session_in_pane "$window_uuid" "$_puuid" 2>/dev/null || true)"
    cwd="$(tmux display-message -p -t "$pane_id" -F '#{pane_current_path}' 2>/dev/null || echo "")"
    capture_txt="$CLAUDE_RESCUE_DATA_HOME/captures/$_puuid.txt"
    capture_meta="$CLAUDE_RESCUE_DATA_HOME/captures/$_puuid.json"
    if tmux capture-pane -peJ -S - -t "$pane_id" > "$capture_txt.tmp" 2>/dev/null; then
      mv "$capture_txt.tmp" "$capture_txt"
    else
      rm -f "$capture_txt.tmp"
    fi
    jq -nc \
      --arg pane_uuid "$_puuid" \
      --arg window_uuid "${window_uuid:-}" \
      --arg session_id "${session_id:-}" \
      --arg pane_id "$pane_id" \
      --arg ts "$(now_iso)" \
      --arg cwd "$cwd" \
      --arg pids "$pids" \
      '{pane_uuid:$pane_uuid, window_uuid:$window_uuid, session_id:$session_id,
        pane_id:$pane_id, ts:$ts, cwd:$cwd,
        pids:($pids | gsub("^ +| +$";"") | split(" "))}' \
      > "$capture_meta.tmp" \
      && mv "$capture_meta.tmp" "$capture_meta"

    # === Soft hibernate: send Ctrl+Z. The tty driver issues SIGTSTP to the
    # foreground process group, the shell takes terminal control back. ===
    tmux send-keys -t "$pane_id" C-z 2>/dev/null || true

    jq -nc --arg pane "$pane_id" --arg puuid "$_puuid" --arg ts "$(now_iso)" \
           --arg pids "$pids" --arg mode "soft" \
      '{pane_id:$pane, pane_uuid:$puuid, ts:$ts, mode:$mode,
        pids:($pids | gsub("^ +| +$";"") | split(" "))}' \
      > "$hibernated_file"

    cmd_hibernated "$pane_id" "$pids" "soft" 2>/dev/null || true

    # ===== STAGE 2: HARD (fg + /exit, with SIGTERM/SIGKILL fallback) =====
    local hard_remaining=$((HARD_DELAY - SOFT_DELAY))
    if [ "$hard_remaining" -le 0 ]; then
      rm -f "$arm_pid_file"
      exit 0
    fi
    sleep "$hard_remaining"
    arm_check

    # Bail out if the hibernated marker is gone (resume already happened) or
    # already hard, or pane is currently focused.
    [ -f "$hibernated_file" ] || { rm -f "$arm_pid_file"; exit 0; }
    local current_mode
    current_mode="$(jq -r '.mode // empty' "$hibernated_file" 2>/dev/null)"
    [ "$current_mode" = "soft" ] || { rm -f "$arm_pid_file"; exit 0; }

    active="$(tmux display-message -p -t "$pane_id" -F '#{window_active}#{pane_active}' 2>/dev/null || echo "00")"
    if [ "$active" = "11" ]; then
      rm -f "$arm_pid_file"
      exit 0
    fi

    # Wake claude (fg restores tcsetpgrp + SIGCONT). Then send `/exit<Enter>`
    # which is claude's own slash command — fires SessionEnd cleanly, flushes
    # transcript, claude exits gracefully. Fall back to SIGTERM then SIGKILL
    # if claude is still alive (e.g. mid-stream and ignoring slash commands).
    tmux send-keys -t "$pane_id" "fg" Enter 2>/dev/null || true
    sleep 1
    tmux send-keys -t "$pane_id" "/exit" Enter 2>/dev/null || true
    sleep 3

    # Check claude is gone; if not, escalate. Each kill is guarded by
    # kill_only_if_comm — recorded pids might have been recycled to unrelated
    # processes after a long defocus + claude crash + new program reusing pid.
    local pid still_alive=""
    for pid in $pids; do
      if kill -0 "$pid" 2>/dev/null; then
        still_alive="$still_alive $pid"
      fi
    done
    if [ -n "${still_alive// /}" ]; then
      for pid in $still_alive; do
        kill_only_if_comm TERM "$pid" "$TARGET_COMM" || true
      done
      sleep 2
      still_alive=""
      for pid in $pids; do
        if kill -0 "$pid" 2>/dev/null; then
          # Re-confirm comm — between TERM and now the pid could have died
          # and been recycled; we already filtered, just re-list survivors.
          still_alive="$still_alive $pid"
        fi
      done
      if [ -n "${still_alive// /}" ]; then
        for pid in $still_alive; do
          kill_only_if_comm KILL "$pid" "$TARGET_COMM" || true
        done
      fi
    fi

    jq --arg mode "hard" --arg ts "$(now_iso)" \
       '. + {mode:$mode, hard_ts:$ts}' \
       "$hibernated_file" > "$hibernated_file.tmp" \
       && mv "$hibernated_file.tmp" "$hibernated_file"

    # Pre-fill `clr <session_id>` at the now-shell prompt (no Enter — user
    # hits Enter when ready). The pane already shows the pre-suspend content
    # (claude exited via /exit which doesn't clear the screen), so no need
    # to also send `claude-rescue print`. The crash-restore path (post
    # resurrect-restore) is the one that needs the explicit print since the
    # pane is reborn empty.
    local resume_sid
    resume_sid="$(jq -r '.session_id // empty' "$capture_meta" 2>/dev/null)"
    if [ -n "$resume_sid" ]; then
      sleep 1
      tmux send-keys -t "$pane_id" "clr $resume_sid" 2>/dev/null || true
    fi

    cmd_hibernated "$pane_id" "$pids" "hard" 2>/dev/null || true
    rm -f "$arm_pid_file"
  ) &
  echo $! > "$arm_pid_file"
  disown 2>/dev/null || true
  trap '' HUP
}

cmd_hibernate_resume() {
  # Cancel any pending hibernate-arm timer and unfreeze the pane based on the
  # mode it was hibernated as.
  #
  # Soft → `fg<Enter>` (shell resumes the suspended claude job, tcsetpgrp
  # restored). Marker + unhibernated event fire here: same claude session
  # continues, no session_start will arrive to clean up later.
  #
  # Hard → true no-op. Claude is dead; the marker is the only state protecting
  # against a crash *after* focus-in (the `clr <sid>` text on the prompt is
  # live readline input, not captured by tmux-resurrect). Marker is cleaned
  # up by cmd_session_start when claude actually starts again — whether via
  # the pre-filled `clr <sid>` or a fresh `cl` for a brand-new session. If
  # the pane dies without ever resuming, cmd_pane_died cleans it up.
  local pane_id="${1:-}"
  [ -n "$pane_id" ] || return 0

  local pane_uuid
  pane_uuid="$(tmux_get_pane_uuid "$pane_id" 2>/dev/null || true)"

  local san="${pane_id//[^A-Za-z0-9]/_}"
  local arm_pid_file="$CLAUDE_RESCUE_CACHE_HOME/hibernated/$san.arm.pid"

  # Read the hibernation mode (if any) BEFORE deciding whether to kill the arm
  # subshell. The arm subshell's role changes by phase:
  #
  #   - pre-soft (no marker yet): the timer is just sleeping; we want to cancel
  #     it so the focused pane doesn't get hibernated.
  #   - soft (marker mode=soft): claude is suspended, the subshell is sleeping
  #     toward hard escalation. Cancel it; we're about to fg<Enter> the job.
  #   - hard (marker mode=hard): claude is already gone. The subshell is in its
  #     short post-/exit cleanup window — sending `clr <sid>` to the prompt,
  #     emitting the hibernated event, removing its own arm.pid. Killing it now
  #     drops the `clr <sid>` pre-fill (the user sees a bare prompt). Leave it.
  local hibernated_file=""
  local mode=""
  if [ -n "$pane_uuid" ]; then
    hibernated_file="$CLAUDE_RESCUE_CACHE_HOME/hibernated/$pane_uuid.json"
    [ -f "$hibernated_file" ] && mode="$(jq -r '.mode // empty' "$hibernated_file" 2>/dev/null)"
  fi

  if [ "$mode" != "hard" ] && [ -f "$arm_pid_file" ]; then
    local arm_pid
    arm_pid="$(cat "$arm_pid_file" 2>/dev/null || true)"
    if [ -n "$arm_pid" ] && kill -0 "$arm_pid" 2>/dev/null; then
      # Only kill if the pid is plausibly an arm subshell. Defends against
      # pid recycling — without this, a stale arm.pid file whose pid was
      # reassigned to an unrelated process could cause us to kill it.
      local arm_args
      arm_args="$(ps -o args= -p "$arm_pid" 2>/dev/null)"
      if printf '%s' "$arm_args" | grep -qE "claude-rescue-log (hibernate-arm|arm-sweep)"; then
        kill "$arm_pid" 2>/dev/null || true
      fi
    fi
    rm -f "$arm_pid_file"
  fi

  [ -z "$hibernated_file" ] && return 0
  [ -f "$hibernated_file" ] || return 0

  case "$mode" in
    soft)
      tmux send-keys -t "$pane_id" "fg" Enter 2>/dev/null || true
      rm -f "$hibernated_file"
      cmd_unhibernated "$pane_id" "$mode" 2>/dev/null || true
      ;;
    hard)
      # No-op. Marker survives until session_start (real resume) or
      # pane_died (orphan cleanup). The in-flight arm subshell (if any)
      # finishes its `clr <sid>` send-keys and removes its own arm.pid.
      :
      ;;
  esac
}

# Arm every backgrounded claude pane that isn't already armed. Triggered on
# client-attached (and session/window changes if wired) so users don't have
# to physically visit each pane to start its hibernation countdown.
#
# pane-focus-out only fires for *the currently-focused* pane transitioning
# away — it never fires for panes that are inactive-in-window or for panes
# the user simply never visited. This sweep fills that gap: at the moments
# we know the client is engaging with the server, we arm all eligible
# backgrounded panes idempotently (per-pane arm.pid check skips already-armed).
cmd_arm_sweep() {
  local pane_id win_act pane_act puuid pane_pid cur_cmd san arm_pid_file
  while IFS=$'\t' read -r pane_id win_act pane_act puuid pane_pid cur_cmd; do
    [ -n "$pane_id" ] || continue
    # Fast guard: pane never ran claude → no work.
    [ -n "$puuid" ] || continue

    # Voluntary-exit detection: pane has a claude UUID but isn't running
    # claude. Catches the SIGKILL / dismiss-"Resume from summary?" / any
    # hook-skipping exit path. Treat as if SessionEnd fired: drop arm.pid,
    # drop active-session file, unset @claude-pane-id.
    #
    # Guards (any one → skip cleanup):
    #   - busy marker present: claude is transiently invisible from
    #     pane_current_command (e.g. spawned a tool subprocess like a wrapper).
    #   - hibernation marker present: soft means claude is Ctrl+Z'd (T state,
    #     pane_current_command reports the shell, but the arm subshell is
    #     load-bearing for the hard escalation). Hard means claude really
    #     exited, but the marker is the crash-restore insurance that survives
    #     until cmd_session_start cleans it — don't unset puuid out from under
    #     it (the marker is keyed by puuid).
    if [ "$cur_cmd" != "claude" ] \
       && ! is_busy "$puuid" \
       && [ ! -f "$CLAUDE_RESCUE_CACHE_HOME/hibernated/$puuid.json" ]; then
      san="${pane_id//[^A-Za-z0-9]/_}"
      rm -f "$CLAUDE_RESCUE_CACHE_HOME/hibernated/$san.arm.pid"
      clear_active_session "$puuid"
      tmux_unset_pane_uuid "$pane_id"
      continue
    fi

    # Currently focused (active pane in an active window): leave it alone.
    [ "$win_act$pane_act" = "11" ] && continue
    san="${pane_id//[^A-Za-z0-9]/_}"
    arm_pid_file="$CLAUDE_RESCUE_CACHE_HOME/hibernated/$san.arm.pid"
    # Already armed (file present AND the recorded pid is alive AND is a real
    # hibernate-arm subshell): don't reset the timer.
    if [ -f "$arm_pid_file" ]; then
      local existing_pid existing_args
      existing_pid="$(cat "$arm_pid_file" 2>/dev/null)"
      if [ -n "$existing_pid" ] && kill -0 "$existing_pid" 2>/dev/null; then
        existing_args="$(ps -o args= -p "$existing_pid" 2>/dev/null)"
        if printf '%s' "$existing_args" | grep -qE "claude-rescue-log (hibernate-arm|arm-sweep)"; then
          continue
        fi
      fi
      # Stale file (dead pid or pid recycled to unrelated process). Remove
      # and re-arm fresh.
      rm -f "$arm_pid_file"
    fi
    cmd_hibernate_arm "$pane_id" "$pane_pid" 2>/dev/null || true
  done < <(tmux list-panes -aF $'#{pane_id}\t#{window_active}\t#{pane_active}\t#{@claude-pane-id}\t#{pane_pid}\t#{pane_current_command}' 2>/dev/null)
}

# --- Dispatch ---------------------------------------------------------------

cmd="${1:-}"; shift || true
case "$cmd" in
  session_start)      cmd_session_start "$@" ;;
  session_end)        cmd_session_end "$@" ;;
  user_prompt_submit) cmd_user_prompt_submit "$@" ;;
  pre_tool_use)       cmd_pre_tool_use "$@" ;;
  post_tool_use)      cmd_post_tool_use "$@" ;;
  stop)               cmd_stop "$@" ;;
  title)              cmd_title "$@" ;;
  title-commit)       cmd_title_commit "$@" ;;
  pane-died)          cmd_pane_died "$@" ;;
  client-detached)    cmd_client_detached "$@" ;;
  hibernated)         cmd_hibernated "$@" ;;
  unhibernated)       cmd_unhibernated "$@" ;;
  resurrect-save)     cmd_resurrect_save "$@" ;;
  resurrect-restore)  cmd_resurrect_restore "$@" ;;
  hibernate-arm)      cmd_hibernate_arm "$@" ;;
  hibernate-resume)   cmd_hibernate_resume "$@" ;;
  arm-sweep)          cmd_arm_sweep "$@" ;;
  '')                 log_err "no subcommand"; exit 2 ;;
  *)                  log_err "unknown subcommand: $cmd"; exit 2 ;;
esac

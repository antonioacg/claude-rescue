#!/usr/bin/env bash
# claude-rescue-resume — wraps `claude` for tmux-resurrect's @resurrect-processes.
#
# Looks up the latest open session for the originating pane's @claude-pane-id
# (the durable identity reapplied by claude-rescue's resurrect-restore hook
# from the sidecar) and adds `-r <session_id>` to the args. Deterministic:
# no scrollback parsing, no transcript heuristics, no timing dependence on
# whether claude has printed its session UUID yet.
#
# DEBUG MODE — prints a banner with the resolved pane_uuid / session_id /
# constructed claude command, then drops into a shell instead of exec'ing.
# Useful for validating the lookup chain without actually starting claude.
# Activate either with `--debug` as the first arg or by setting
# CLAUDE_RESCUE_RESUME_DEBUG=1 in the environment.

set -uo pipefail

# Resolve $0 through any symlinks so we find lib/common.sh regardless of how
# this binary was invoked (direct, via ~/.local/bin/ symlink, etc.).
__script="$0"
while [ -L "$__script" ]; do
  __link="$(readlink "$__script")"
  case "$__link" in
    /*) __script="$__link" ;;
    *)  __script="$(cd "$(dirname "$__script")" && pwd)/$__link" ;;
  esac
done
REPO="$(cd "$(dirname "$__script")/.." && pwd)"
# shellcheck source=../lib/common.sh
. "$REPO/lib/common.sh"

# --- Observability: per-invocation log ------------------------------------
# Every wrapper invocation appends to wrapper.log: one "invoked" line on
# entry with verbatim argv + pane + pids, one "resolved" line just before
# exec with the lookup decisions. Lets us answer post-incident: did the
# wrapper even run for pane X? With what args? What did it decide? Failure
# to write the log is silent — we never block the wrapper on a log error.
__rescue_log_dir="${CLAUDE_RESCUE_DATA_HOME:-${XDG_DATA_HOME:-$HOME/.local/share}/claude-rescue}"
mkdir -p "$__rescue_log_dir" 2>/dev/null || true
__rescue_wrapper_log="$__rescue_log_dir/wrapper.log"
__rescue_log() {
  printf '[%s] %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$*" >> "$__rescue_wrapper_log" 2>/dev/null || true
}
{
  __ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  # Observability: surface the pane's current state at wrapper entry.
  # If claude is already alive in the pane's process subtree when the
  # wrapper is invoked, any send-keys that delivered our cmdline landed in
  # claude's input — the leak signature seen in pane %43 on 2026-05-19.
  __pane_cur_cmd=""
  __pane_pid=""
  __claudes=0
  if [ -n "${TMUX_PANE:-}" ]; then
    __pane_cur_cmd="$(tmux display-message -p -t "$TMUX_PANE" -F '#{pane_current_command}' 2>/dev/null || echo '<unknown>')"
    __pane_pid="$(tmux display-message -p -t "$TMUX_PANE" -F '#{pane_pid}' 2>/dev/null || echo '')"
    if [ -n "$__pane_pid" ]; then
      __q=("$__pane_pid")
      while [ "${#__q[@]}" -gt 0 ]; do
        __cur="${__q[0]}"; __q=("${__q[@]:1}")
        for __ch in $(pgrep -P "$__cur" 2>/dev/null); do
          __q+=("$__ch")
          __cmd="$(ps -o comm= -p "$__ch" 2>/dev/null | sed 's|.*/||' | tr -d ' ')"
          [ "$__cmd" = "claude" ] && __claudes=$((__claudes + 1))
        done
      done
    fi
  fi
  printf '[%s] invoked pid=%s ppid=%s pane=%s pane_cur_cmd=%s claudes_in_subtree=%s argc=%s argv=' \
    "$__ts" "$$" "${PPID:-?}" "${TMUX_PANE:-<unset>}" "${__pane_cur_cmd:-<unset>}" "$__claudes" "$#"
  if [ "$#" -gt 0 ]; then printf '%q ' "$@"; fi
  printf '\n'
} >> "$__rescue_wrapper_log" 2>/dev/null || true

# --- Flag handling: consume --debug if first arg ---------------------------
debug=0
if [ "${1:-}" = "--debug" ]; then
  debug=1
  shift
fi
[ "${CLAUDE_RESCUE_RESUME_DEBUG:-}" = "1" ] && debug=1

# --- Rebuild args ---------------------------------------------------------
# Two jobs:
#   1. Glue multi-word flag values back together. tmux-resurrect's send-keys
#      feeds the saved pane_full_command into the shell as a plain string,
#      which gets tokenised on whitespace, so flag values that originally
#      contained spaces (e.g. `--append-system-prompt "Session start: ..."`)
#      arrive split. Without re-gluing them, those tokens leak into claude
#      as user-message input ("start:" being the most visible symptom).
#   2. Strip session-creation flags that don't belong on a deterministic
#      resume:
#        --fork              would create another fork on top of the resume
#        -r / --resume UUID  saved value may be stale; lookup is authoritative
#        -c / --continue     "resume the most recent session"; we know the exact one
#      The resume target is then added explicitly via -r <session_id> from the
#      find-sessions lookup below.
# Logic mirrors ~/.config/tmux/scripts/claude-restore.sh for the value-gluing.
uuid_re='[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}'
rebuilt=()
existing_uuid=""
i=1
while [ $i -le $# ]; do
  arg="${!i}"
  if [[ "$arg" =~ ^${uuid_re}$ ]]; then
    rebuilt+=("$arg")
  elif [ "$arg" = "-r" ] || [ "$arg" = "--resume" ]; then
    # Drop the flag; capture the UUID arg as a fallback target.
    next=$((i + 1))
    if [ $next -le $# ]; then existing_uuid="${!next}"; i=$next; fi
  elif [ "$arg" = "--fork-session" ]; then
    # Drop the flag; capture the UUID arg as a fallback target (the saved
    # session was a fork of THAT one — resuming the fork's session_id is the
    # right behaviour, but if our pane_uuid lookup misses, falling back to
    # the parent is better than nothing).
    next=$((i + 1))
    if [ $next -le $# ] && [[ "${!next}" =~ ^${uuid_re}$ ]]; then
      existing_uuid="${existing_uuid:-${!next}}"
      i=$next
    fi
  elif [ "$arg" = "--fork" ] || [ "$arg" = "-c" ] || [ "$arg" = "--continue" ]; then
    # Creation-time hints; drop on resume.
    :
  elif [[ "$arg" == -* ]]; then
    rebuilt+=("$arg")
    # Glue following non-flag, non-UUID tokens into a single space-joined value.
    value=""
    while [ $((i + 1)) -le $# ]; do
      ni=$((i + 1))
      next="${!ni}"
      if [[ "$next" == -* ]] || [[ "$next" =~ ^${uuid_re}$ ]]; then
        break
      fi
      value="${value:+$value }$next"
      i=$((i + 1))
    done
    [ -n "$value" ] && rebuilt+=("$value")
  else
    rebuilt+=("$arg")
  fi
  i=$((i + 1))
done
# bash 3.2 + set -u treats an empty array's ${arr[@]} as unbound. When the
# saved cmd is just `claude -r <UUID>` (no other args), the rebuild loop
# strips both args and `rebuilt` stays empty. Guard the expansion.
if [ "${#rebuilt[@]}" -gt 0 ]; then
  set -- "${rebuilt[@]}"
else
  set --
fi

# --- Query pane uuid + look up the resume target via find-sessions --------
pane_uuid=""
if [ -n "${TMUX_PANE:-}" ]; then
  pane_uuid="$(tmux show-options -pv -t "$TMUX_PANE" @claude-pane-id 2>/dev/null || true)"
fi

# Priority-1: hook-driven active session_id file. Written by cmd_session_start
# on every source (including in-claude /resume), so it tracks the user's
# current session even when tmux-resurrect's saved `-r <sid>` cmdline has gone
# stale. Survives a tmux server restart (lives under $DATA, indexed by the
# durable pane_uuid that the sidecar preserves).
active_sid=""
if [ -n "$pane_uuid" ]; then
  active_sid="$(read_active_session "$pane_uuid")"
fi

# Priority-2: find-sessions over the event log. Falls back to the most-recent
# session for this pane_uuid that has a transcript on disk.
found_sid=""
found_cwd=""
if [ -z "$active_sid" ] && [ -n "$pane_uuid" ]; then
  # `--open-only` is intentionally NOT used: it filters by absence of a
  # session_end event, but a SIGKILL'd claude leaves the session "open" in
  # our log without a transcript. find-sessions already filters to sessions
  # that have a transcript on disk (that's the real "resumable" criterion);
  # take the most recent of those.
  US=$'\x1f'
  row="$("$REPO/bin/claude-rescue" find-sessions \
          --pane-uuid "$pane_uuid" 2>/dev/null | head -1)"
  if [ -n "$row" ]; then
    # find-sessions cols: session_id, window_uuid, pane_uuid, started, ended, cwd, source, window_name, last_title
    found_sid="$(printf '%s' "$row" | awk -v FS="$US" '{print $1}')"
    found_cwd="$(printf '%s' "$row" | awk -v FS="$US" '{print $6}')"
  fi
fi

# --- Decide final args ----------------------------------------------------
# Resolve the resume target with this priority:
#   1. $DATA/active/<pane_uuid> — hook-driven, tracks in-claude /resume
#   2. find-sessions lookup result — derived from the append-only event log,
#      keyed by the durable pane_uuid (fallback when the active file was
#      cleared by SessionEnd or never written)
#   3. None — exec claude without -r, starting a fresh session
#
# Saved -r in the tmux-resurrect cmdline is intentionally NOT a fallback.
# It's set at claude launch and never updated when the user does an in-claude
# /resume — so trusting it silently resumes the wrong (pre-/resume) session,
# corrupting on-disk transcripts if both sessions are still live elsewhere.
# We parse existing_uuid above only to (a) strip it from final_args so it
# can't be passed through, and (b) surface it in debug output for diagnosis.
final_args=("$@")
target_uuid=""
if [ -n "$active_sid" ]; then
  target_uuid="$active_sid"
elif [ -n "$found_sid" ]; then
  target_uuid="$found_sid"
fi
if [ -n "$target_uuid" ]; then
  final_args+=(-r "$target_uuid")
fi

# --- Debug mode: banner + drop to shell instead of exec'ing claude --------
if [ "$debug" -eq 1 ]; then
  {
    echo "============================================================"
    echo " claude-rescue-resume — DEBUG"
    echo "============================================================"
    echo " TMUX_PANE        : ${TMUX_PANE:-<unset>}"
    echo " @claude-pane-id  : ${pane_uuid:-<not set>}"
    echo " active-file      : ${active_sid:-<not set>}"
    echo " find-sessions    : ${found_sid:-<no match>}"
    echo " existing -r arg  : ${existing_uuid:-<none>}"
    echo " resume target    : ${target_uuid:-<none — would start a fresh session>}"
    echo " session cwd      : ${found_cwd:-<n/a>}"
    echo
    echo " would exec:"
    printf '   claude'
    printf ' %q' "${final_args[@]}"
    printf '\n'
    echo "============================================================"
    echo
  } >&2
  exec "${SHELL:-/bin/zsh}" -i
fi

# --- cwd-mismatch detection -----------------------------------------------
# When resuming with -r <sid>, claude looks up the transcript jsonl under
# the project dir derived from the SHELL's current cwd, not the session's
# original cwd. If they differ, claude prints "No conversation found with
# session ID: <sid>" and the user has to figure out where to cd. Catch the
# divergence here so the log shows it the moment it happens.
#
# Source of truth for the session's cwd at hibernation time:
# $DATA/captures/<pane_uuid>.json. If absent (pane was never hibernated,
# or capture isn't current), fall back to find-sessions's reported cwd.
session_cwd=""
if [ -n "$pane_uuid" ] && [ -f "$__rescue_log_dir/captures/$pane_uuid.json" ]; then
  session_cwd="$(jq -r '.cwd // empty' "$__rescue_log_dir/captures/$pane_uuid.json" 2>/dev/null || true)"
fi
[ -z "$session_cwd" ] && session_cwd="${found_cwd:-}"
cwd_match="unknown"
if [ -n "$session_cwd" ]; then
  if [ "$PWD" = "$session_cwd" ]; then cwd_match="Y"; else cwd_match="N"; fi
fi

# --- Live: exec claude with the resolved args ------------------------------
__rescue_log "resolved pid=$$ pane=${TMUX_PANE:-<unset>} pane_uuid=${pane_uuid:-} active_sid=${active_sid:-} find_sessions_sid=${found_sid:-} saved_uuid=${existing_uuid:-} target=${target_uuid:-<fresh>} pwd=$PWD session_cwd=${session_cwd:-<none>} cwd_match=$cwd_match"
exec claude "${final_args[@]}"

#!/usr/bin/env bash
# claude-rescue-watcher-ensure — idempotent spawn for the watcher daemon.
#
# Wired into tmux's client-attached hook. Cheap to call repeatedly: if a
# watcher is already running (PID file points at a live process), this is
# a no-op. Otherwise, spawn claude-rescue-watcher detached so tmux's
# run-shell wrapper returns immediately and the watcher outlives its
# originating client.

set -uo pipefail

__script="$0"
while [ -L "$__script" ]; do
  __link="$(readlink "$__script")"
  case "$__link" in
    /*) __script="$__link" ;;
    *)  __script="$(cd "$(dirname "$__script")" && pwd)/$__link" ;;
  esac
done
REPO="$(cd "$(dirname "$__script")/.." && pwd)"
# shellcheck source=../lib/common.sh
. "$REPO/lib/common.sh"

# Per-server PID file — second tmux server gets its own watcher running in
# parallel (matches the per-server $OUTDIR convention in the daemon itself).
SOCKET_PATH="$(tmux display-message -p '#{socket_path}' 2>/dev/null || true)"
SERVER_NAME="$(basename "${SOCKET_PATH:-default}")"
[ -z "$SERVER_NAME" ] && SERVER_NAME="default"
PIDFILE="$CLAUDE_RESCUE_DATA_HOME/watcher-$SERVER_NAME.pid"

if [ -f "$PIDFILE" ]; then
  other_pid="$(cat "$PIDFILE" 2>/dev/null || echo "")"
  if [ -n "$other_pid" ] && kill -0 "$other_pid" 2>/dev/null; then
    exit 0
  fi
fi

nohup "$REPO/bin/claude-rescue-watcher" </dev/null >/dev/null 2>&1 &
disown 2>/dev/null || true

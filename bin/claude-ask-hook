#!/usr/bin/env bash
# claude-ask-hook — combined Pre/PostToolUse hook for claude-harness.
#
# Two independent per-session knobs drive the hook:
#
#   ask_on_edits / ask_on_bash — when true, return permissionDecision: "ask"
#     for the matching tool class so Claude pauses for manual confirmation.
#
#   editor_on_edits — when true, pop the target file open in $editor_command
#     for every Edit/Write/NotebookEdit/MultiEdit, INDEPENDENT of the ask
#     gates. Lets you "watch" Claude's edits autonomously without forcing
#     the prompt UX.
#
# The two are decoupled on purpose: you might want to gate edits without
# the editor pop (just stop and confirm), or pop the editor without gating
# (autonomous progress tracking).
#
# Editor spawn rules:
#   PreToolUse  + Edit                       → spawn at the line of old_string
#   PreToolUse  + Write/NotebookEdit/MultiEdit → skip; file doesn't exist yet
#                                              (the PostToolUse branch covers
#                                              it after the write lands)
#   PostToolUse + Write/NotebookEdit          → spawn at line 1
#
# Wire from ~/.claude/settings.json:
#
#   {
#     "hooks": {
#       "PreToolUse": [
#         {
#           "matcher": "Edit|Write|NotebookEdit|MultiEdit|Bash",
#           "hooks": [{ "type": "command", "command": "claude-ask-hook" }]
#         }
#       ],
#       "PostToolUse": [
#         {
#           "matcher": "Write|NotebookEdit",
#           "hooks": [{ "type": "command", "command": "claude-ask-hook" }]
#         }
#       ]
#     }
#   }

set -uo pipefail

__script="$0"
while [ -L "$__script" ]; do
  __link="$(readlink "$__script")"
  case "$__link" in
    /*) __script="$__link" ;;
    *)  __script="$(cd "$(dirname "$__script")" && pwd)/$__link" ;;
  esac
done
REPO="$(cd "$(dirname "$__script")/.." && pwd)"
# shellcheck source=../lib/common.sh
. "$REPO/lib/common.sh"
# shellcheck source=../lib/session-config.sh
. "$REPO/lib/session-config.sh"

# Outside tmux there's no `claude-session-config` popup to toggle the knobs
# back off, which makes a stuck flag painful. Bail silently when $TMUX is
# unset so the harness is a tmux-only feature; users who want it elsewhere
# can comment out this guard.
[ -n "${TMUX:-}" ] || exit 0

payload="$(cat)"
hook_event="$(jq -r '.hook_event_name // ""' <<<"$payload")"
session_id="$(jq -r '.session_id // ""'      <<<"$payload")"
tool_name="$(jq -r '.tool_name // ""'        <<<"$payload")"
file_path="$(jq -r '.tool_input.file_path // .tool_input.notebook_path // ""' <<<"$payload")"

# Spawn the configured editor on <file>:<line>. Skips if the file is missing,
# editor_on_edits is off, or no editor_command is set. Best-effort; never
# blocks the hook.
spawn_editor() {
  local target_file="$1" target_line="${2:-1}"
  [ -n "$target_file" ] || return 0
  [ -f "$target_file" ] || return 0
  [ "$(get_session_config_value "$session_id" "editor_on_edits")" = "true" ] || return 0
  local editor_cmd
  editor_cmd="$(get_session_config_value "$session_id" "editor_command")"
  [ -n "$editor_cmd" ] && [ "$editor_cmd" != "null" ] || return 0
  local target="$target_file:$target_line"
  # eval to allow flag args like `code -g`. Detach so Claude doesn't wait.
  ( eval "$editor_cmd \"\$target\"" >/dev/null 2>&1 & ) || true
}

# PostToolUse: only opens new files for Write/NotebookEdit (Edit was already
# opened by Pre on existing files). No JSON output.
if [ "$hook_event" = "PostToolUse" ]; then
  case "$tool_name" in
    Write|NotebookEdit)
      spawn_editor "$file_path" 1
      ;;
  esac
  exit 0
fi

# PreToolUse path -----------------------------------------------------------

# 1) Editor spawn for Edit on existing files — fires regardless of ask gate.
if [ "$tool_name" = "Edit" ] && [ -f "$file_path" ]; then
  # Anchor at the first non-empty line of old_string. Falls back to line 1
  # on miss (multi-line old_string with leading whitespace mismatch, etc.).
  line=1
  needle="$(jq -r '.tool_input.old_string // ""' <<<"$payload" | sed -n '/./{p;q;}')"
  if [ -n "$needle" ]; then
    hit="$(grep -nF -- "$needle" "$file_path" 2>/dev/null | head -1 | cut -d: -f1)"
    [ -n "$hit" ] && line="$hit"
  fi
  spawn_editor "$file_path" "$line"
fi

# 2) Ask decision — independent of editor spawn.
ask=false
gate=""
case "$tool_name" in
  Edit|Write|NotebookEdit|MultiEdit)
    if [ "$(get_session_config_value "$session_id" "ask_on_edits")" = "true" ]; then
      ask=true; gate="edits"
    fi
    ;;
  Bash)
    if [ "$(get_session_config_value "$session_id" "ask_on_bash")" = "true" ]; then
      ask=true; gate="bash"
    fi
    ;;
esac

if [ "$ask" != true ]; then
  exit 0
fi

jq -nc --arg gate "$gate" '
  {
    hookSpecificOutput: {
      hookEventName: "PreToolUse",
      permissionDecision: "ask",
      permissionDecisionReason: ("claude-harness: " + $gate + " gate active for this session")
    }
  }
'
